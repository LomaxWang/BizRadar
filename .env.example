# ============================================================
# IdeaHunter 环境变量配置示例
# 复制此文件为 .env 并填写真实值：cp .env.example .env
# ============================================================

# ---- LLM 配置（必填）----
# 支持所有 OpenAI-Compatible 接口（DeepSeek、Kimi、OpenAI、SiliconFlow 等）
LLM_API_KEY="sk-your-api-key-here"
LLM_BASE_URL="https://api.deepseek.com/v1"
LLM_MODEL="deepseek-chat"

# ---- HTTP API 鉴权（可选）----
# 若留空，所有 API 端点无需认证（仅本地开发时使用）
IDEAHUNTER_API_KEY=""

# ---- 存储路径（可选，相对于运行目录）----
IDEAHUNTER_SQLITE_PATH="data/ideahunter.db"
OUTPUT_DIR="output"

# ---- 核心筛选参数 ----
SCORE_APPROVE_MIN=65   # Critic 评分通过阈值（0-100）
MIN_TEXT_CHARS=12      # 帖子最短有效字符数

# ---- 多跳检索（可选）----
# 开启后对每条内容额外拉取评论/正文，内容更丰富，但速度变慢
MULTI_HOP_ENABLED=false
MULTI_HOP_MAX_COMMENTS=3

# ---- 关键词驱动搜索（可选）----
# 关键词池：每次扫描随机抽取，驱动各插件的搜索轨道
KEYWORD_POOL='["效率工具","手动操作","求推荐软件","太麻烦了","自动化","重复劳动","批量处理","工作流","发货","库存同步","记账","报表","招聘","客服","私域运营","报销","对账","合同管理","排班","考勤","薪资核算","内容创作","社群运营"]'
KEYWORDS_PER_RUN=3

# ---- Hot + New 双轨（可选）----
HOT_MODE_ENABLED=false
HN_HOT_MIN_POINTS=30

# ---- 定时调度（可选）----
SCHEDULE_ENABLED=false
SCHEDULE_CRON="0 9 * * *"
# 支持所有已注册数据源，包括新增的：producthunt, indiehackers, appstore, sspai, kr36, twitter, weibo
SCHEDULE_SOURCES='["v2ex"]'

# ---- 数据源插件额外配置 ----

# Serper.dev API Key（小红书/知乎/ProductHunt/IndieHackers/36氪 搜索增强，https://serper.dev 免费注册）
SERPER_API_KEY=""

# [App Store 差评] 无需 Key，通过 iTunes RSS 获取
APPSTORE_TERMS="project management,invoicing,time tracking,crm,scheduling"  # 美区搜索词（英文）
APPSTORE_APP_IDS=""          # 直接指定 App ID（逗号分隔），留空则自动搜索
APPSTORE_COUNTRY="us"        # 国家代码：us=美区，cn=中国区

# [Twitter/X] 需要 Developer 账号（https://developer.twitter.com，免费档足够）
TWITTER_BEARER_TOKEN=""
TWITTER_MAX_RESULTS=20
TWITTER_QUERIES=""           # 自定义搜索查询，用 || 分隔（留空使用默认痛点查询）

# [微博热搜] 无需 Key，自动获取实时热搜
WEIBO_HOT_LIMIT=20
WEIBO_TECH_ONLY=true         # true = 过滤娱乐/体育词条

# ---- 通知推送（可选，均留空则只在控制台输出）----
NOTIFIER_FEISHU_WEBHOOK=""
NOTIFIER_WECOM_WEBHOOK=""
NOTIFIER_CUSTOM_WEBHOOK=""
NOTIFIER_CONSOLE_ENABLED=true
