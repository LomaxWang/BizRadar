# ============================================================
# BizRadar 环境变量配置示例
# 1. 复制此文件：cp .env.example .env
# 2. 填写 LLM_API_KEY（必填），其余均有默认值，按需调整
# ============================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【必填】LLM 配置
# 支持所有 OpenAI-Compatible 接口：
#   DeepSeek  → https://platform.deepseek.com  (deepseek-chat 性价比最高)
#   云雾 API  → https://yunwu.ai/v1            (国内中转，支持 GPT-4o 等)
#   Kimi      → https://platform.moonshot.cn/v1
#   SiliconFlow → https://api.siliconflow.cn/v1
#   OpenAI    → https://api.openai.com/v1
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LLM_API_KEY="sk-your-api-key-here"
LLM_BASE_URL="https://api.deepseek.com/v1"
LLM_MODEL="deepseek-chat"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【可选】HTTP API 访问鉴权
# 留空 = 无需认证（仅限本地/内网）
# 填写后所有 API 请求需携带 Header: Authorization: Bearer <key>
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BIZRADAR_API_KEY=""

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【可选】数据存储路径（Docker 用户无需修改，已通过卷挂载）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
IDEAHUNTER_SQLITE_PATH="data/ideahunter.db"
OUTPUT_DIR="output"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【可选】核心筛选参数
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SCORE_APPROVE_MIN=65   # Critic 评分通过阈值（0-100），越低通过的点子越多
MIN_TEXT_CHARS=12      # 帖子最短有效字符数，过短的内容直接跳过

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【可选】关键词驱动搜索
# 每次扫描从关键词池中随机抽取，驱动各插件的搜索轨道
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
KEYWORD_POOL='["效率工具","手动操作","求推荐软件","太麻烦了","自动化","重复劳动","批量处理","工作流","发货","库存同步","记账","报表","招聘","客服","私域运营","报销","对账","合同管理","排班","考勤","薪资核算","内容创作","社群运营"]'
KEYWORDS_PER_RUN=3

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【可选】定时自动扫描（适合长期挂在服务器上）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SCHEDULE_ENABLED=false
SCHEDULE_CRON="0 9 * * *"   # 每天早 9 点自动扫描
SCHEDULE_SOURCES='["v2ex"]' # 支持所有已注册数据源

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【可选】数据源插件额外配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Serper.dev API Key（用于搜索增强：小红书/知乎/ProductHunt 等）
# 免费注册：https://serper.dev
SERPER_API_KEY=""

# App Store 差评（无需 Key，通过 iTunes RSS 获取）
APPSTORE_TERMS="project management,invoicing,time tracking,crm,scheduling"
APPSTORE_APP_IDS=""
APPSTORE_COUNTRY="us"

# Twitter/X（需要 Developer 账号：https://developer.twitter.com 免费档足够）
TWITTER_BEARER_TOKEN=""
TWITTER_MAX_RESULTS=20
TWITTER_QUERIES=""

# 微博热搜（无需 Key）
WEIBO_HOT_LIMIT=20
WEIBO_TECH_ONLY=true

# 多跳检索（开启后拉取评论，内容更丰富，但速度变慢）
MULTI_HOP_ENABLED=false
MULTI_HOP_MAX_COMMENTS=3

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【可选】通知推送（均留空则只在控制台输出）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NOTIFIER_FEISHU_WEBHOOK=""   # 飞书 Webhook
NOTIFIER_WECOM_WEBHOOK=""    # 企业微信 Webhook
NOTIFIER_CUSTOM_WEBHOOK=""   # 自定义 Webhook
NOTIFIER_CONSOLE_ENABLED=true
